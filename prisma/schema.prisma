generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  username         String    @unique
  phone            String
  role             Role      @default(GUEST)
  password         String
  avatar           String?
  avatarPublicId   String?
  bio              String?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  bookings         Booking[]
  listings         Listing[]
}

model Listing {
  id            Int            @id @default(autoincrement())
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  type          ListingType
  amenities     String
  rating        Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  hostId        Int
  bookings      Booking[]
  host          User           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  photos        ListingPhoto[]

  @@index([location])
  @@index([pricePerNight])
  @@index([type])
  @@index([hostId])
  @@index([type, location])
}

model ListingPhoto {
  id        Int     @id @default(autoincrement())
  url       String
  publicId  String
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Booking {
  id         Int           @id @default(autoincrement())
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  guestId    Int
  listingId  Int
  guest      User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@index([listingId])
  @@index([listingId, checkIn, checkOut])
}

enum Role {
  ADMIN
  HOST
  GUEST
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}